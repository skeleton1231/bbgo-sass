# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.supabase.co:5432/postgres
SUPABASE_ANON_KEY=your-anon-key

# Manager
ENCRYPTION_KEY=base64-encoded-32-byte-key
MANAGER_TOKEN=your-secure-random-token

# Docker
BBGO_IMAGE=bbgo-base:latest
DOCKER_NETWORK=saas_bbgo-net
DATA_VOLUME=saas_bbgo-data
DATA_DIR=/data

# Ports
BBGO_PORT=8080
BBGO_GRPC_PORT=9090
MANAGER_PORT=8090

# Shared marketdata service (Docker DNS name)
MARKETDATA_ADDR=bbgo-marketdata:9090

# WebSocket allowed origins (comma-separated, defaults to localhost if empty)
WS_ALLOWED_ORIGINS=

# Market data (Binance API for shared market data service)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Domain for TLS (Caddy auto-HTTPS)
DOMAIN=your-domain.com
