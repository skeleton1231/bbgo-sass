# Manager API token (shared secret for internal auth)
MANAGER_TOKEN=

# 32-byte hex key for AES-GCM credential encryption
ENCRYPTION_KEY=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_DB_URL=
SUPABASE_ANON_KEY=

# Docker
BBGO_IMAGE=bbgo-base:latest
DOCKER_NETWORK=saas_bbgo-net
DATA_VOLUME=saas_bbgo-data
DATA_DIR=/data

# Ports
BBGO_PORT=8080
BBGO_GRPC_PORT=9090
MANAGER_PORT=8090

# Shared marketdata service (Docker DNS name)
MARKETDATA_ADDR=bbgo-marketdata:9090

# Exchange API keys (for marketdata public stream — at least one exchange)
BINANCE_API_KEY=
BINANCE_API_SECRET=
