# ============================================
# BBGO SaaS — shared config
# Used by: docker-compose.yml (variable substitution), manager (standalone)
# Web uses its own: web/.env.local
# ============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Secrets
ENCRYPTION_KEY=your-32-byte-base64-encryption-key
MANAGER_TOKEN=generate-a-random-secret-here

# Exchange keys (for marketdata container)
BINANCE_API_KEY=
BINANCE_API_SECRET=
