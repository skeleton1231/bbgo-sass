# ============================================================
# BBGO SaaS — Production environment template
# Copy to saas/.env.prod and fill in real values. NEVER commit .env.prod.
# ============================================================

# --- Public domain + TLS ---
DOMAIN=bbgo.your-domain.com
ACME_EMAIL=ops@your-domain.com

# --- Supabase (manager uses service-role key) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...REDACTED
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT:CHANGEME@aws-0-region.pooler.supabase.com:6543/postgres

# --- Supabase (web uses anon key — public, safe to expose) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...REDACTED
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...REDACTED

# --- Manager secrets ---
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=base64-32-byte-key-CHANGEME
# Generate with: openssl rand -hex 32
MANAGER_TOKEN=hex-32-byte-shared-secret-CHANGEME

# --- Binance (marketdata container only) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Build metadata (optional; populated by CI) ---
BUILD_VERSION=prod-local

# --- Logging ---
LOG_LEVEL=info
# Set to text for human-readable logs (debugging). JSON is the default for
# structured ingestion (Datadog, Loki, GCP Logging).
LOG_FORMAT=json

# --- Go module proxy (build-time only) ---
# Leave default for public internet; set to internal mirror behind GFW.
# GOPROXY_URL=https://proxy.golang.org,direct
